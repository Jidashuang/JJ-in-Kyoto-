# Public env vars (safe to expose in the browser bundle).
# Copy this file to `.env.local` for local dev, or set the same keys in your
# Vercel project settings for production.

# ─── Required for production ──────────────────────────────────────────────
# Canonical site URL — drives metadataBase, JSON-LD URLs, and OG image absolute paths.
# In Vercel set this to your custom domain once it's wired up.
NEXT_PUBLIC_SITE_URL=https://jjinkyoto.com

# ─── Optional: analytics ──────────────────────────────────────────────────
# Pick one (or both — they don't conflict).
# Plausible: set the domain you registered in your Plausible account.
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=jjinkyoto.com
# NEXT_PUBLIC_PLAUSIBLE_SCRIPT=https://plausible.io/js/script.js
#
# Google Analytics 4: paste the measurement ID (e.g. G-ABCD1234).
# NEXT_PUBLIC_GA_ID=

# ─── Optional: search-engine site verification ────────────────────────────
# These render <meta name="..." content="..."> tags via Next's metadata API.
# Each is independent — only the ones you set are emitted.
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
# NEXT_PUBLIC_YANDEX_VERIFICATION=
# NEXT_PUBLIC_BING_VERIFICATION=
